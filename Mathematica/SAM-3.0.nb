     RowBox[{
     "use", " ", "Simplify", " ", "or", " ", "Identity", " ", "instead", " ", 
      "of", " ", "the", " ", "default", " ", "FullSimplify"}]}]}], " ", 
   "*)"}]}]], "Input",
