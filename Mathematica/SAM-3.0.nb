       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"paper", " ", 
           RowBox[{"App", ".", " ", "A"}]}], ")"}], " ", "--"}], "--"}], "\n",
        "   ", 
       RowBox[{"kappa", "^", "NLO_n"}]}]}], " ", "=", " ", 
