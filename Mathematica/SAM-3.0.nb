Cell[TextData[{
 "Composing with ",
 StyleBox["ObservableIsCharge", "Code"],
 " additionally imposes ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", "=", 
    SubscriptBox["B", "in"]}], TraditionalForm]],ExpressionUUID->
  "2e1e5426-ce59-4da0-8a0f-c165df98768a"],
 "  (the observable is the accepted conserved charge). The observable and \
charge indices then merge, every mixed (XB) cumulant collapses to a pure \
B-cumulant, and one recovers the classical SAM-1.0 accepted-charge formulas \
\[LongDash] paper Eqs. (73)\[Dash](76), originally arXiv:2003.13905. Outputs \
use \[Beta] = 1 - \[Alpha]."
}], "Text",
 CellChangeTimes->{{3.991183784889352*^9, 
  3.991183790106059*^9}},ExpressionUUID->"de44f5ee-7667-4b67-b800-\
d1b25f4d6d80"],

