       RowBox[{"SAM1", "      ", "--"}], " ", "SAM"}], "-", 
      RowBox[{"1.0", " ", 
       RowBox[{"(", "i", ")"}]}], "+", 
      RowBox[{"(", "ii", ")"}]}], ":", " ", 
     RowBox[{"generic", " ", "observable", " ", 
