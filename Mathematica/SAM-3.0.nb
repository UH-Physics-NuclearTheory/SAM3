            "rule"}]}]}], ")"}]}]}]}]}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"SAM1", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"kGCE", "[", 
         RowBox[{"n_List", ",", "m_List"}], "]"}], "/;", 
        RowBox[{"!", 
         RowBox[{"ZeroMIQ", "[", "n", "]"}]}]}], ":>", 
       RowBox[{"\[Alpha]", " ", 
        RowBox[{"kGCE", "[", 
         RowBox[{"n", ",", "m"}], "]"}]}]}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"ObservableIsCharge", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"kGCE", "[", 
         RowBox[{"n_List", ",", "m_List"}], "]"}], "/;", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"ZeroMIQ", "[", "n", "]"}]}], "||", 
         RowBox[{"!", 
          RowBox[{"ZeroMIQ", "[", "m", "]"}]}]}]}], ":>", 
       RowBox[{"kB", "[", 
        RowBox[{
         RowBox[{"Total", "[", "n", "]"}], "+", 
         RowBox[{"Total", "[", "m", "]"}]}], "]"}]}], "}"}]}], ";"}], "\n", 
