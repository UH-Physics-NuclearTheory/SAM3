       "Subsuperscript"], ")"}], "2"], 
    TemplateBox[{"\[Kappa]", "\"2\"", 
      StyleBox["\"B\"", Italic, StripOnInput -> False]},
     "Subsuperscript"]]}],
  HoldForm]], "Output",
 CellChangeTimes->{3.991828611332817*^9},
 CellLabel->
  "Out[143]=",ExpressionUUID->"ddff6096-61f4-4214-9347-2249958a9300"]
}, Open  ]],

