   RowBox[{"{", "2", "}"}], "]"}], "    ", 
  RowBox[{"(*", " ", 
   RowBox[{
    SubsuperscriptBox["\[Kappa]", "2", 
     RowBox[{"X", "\[VerticalSeparator]", "B"}]], ",", " ", 
    RowBox[{"all", " ", "defaults"}]}], " ", "*)"}]}]], "Input",
 CellLabel->
  "In[143]:=",ExpressionUUID->"486fa9fe-80b6-47cf-b385-e67530efed59"],

