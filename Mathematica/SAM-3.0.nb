      "/.", " ", 
      RowBox[{
       RowBox[{"ObservableIsCharge", "\n", "   ", "*", " ", "cBinom"}], " ", 
       "+", " ", "kappaBinRule", " ", "+", " ", 
       RowBox[{
        RowBox[{"BinomialAcceptance", " ", "--"}], " ", "binomial", " ", 
        "acceptance", " ", "limit", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"d", "=", 
           RowBox[{"s", "=", 
            RowBox[{"1", " ", "only"}]}]}], ";", "\n", "        ", 
          RowBox[{
           RowBox[{"the", " ", "multi"}], "-", 
           RowBox[{"d", " ", "/", " ", "multi"}], "-", 
           RowBox[{"charge", " ", "framework", " ", "with", " ", "species"}], 
