                    RowBox[{"{", "}"}], ",", " ", "ce"}], "}"}]}], "]"}]}], 
                ")"}], ",", "\n", "        ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", "}"}], ",", " ", "opt"}], "}"}]}], "]"}]}], 
            ")"}], ",", "\n", "     ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", "}"}], ",", " ", "raw"}], "}"}]}], "]"}]}], ";", 
        "\n", "  ", 
        RowBox[{"ren", " ", "=", " ", 
         RowBox[{"MapIndexed", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"First", "[", "#1", "]"}], " ", "->", " ", 
              RowBox[{"Symbol", "[", 
               RowBox[{"\"\<tmp\>\"", " ", "<>", " ", 
                RowBox[{"ToString", "[", 
                 RowBox[{"First", "[", "#2", "]"}], "]"}]}], "]"}]}], ")"}], 
            " ", "&"}], ",", " ", "assigns"}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"assigns", " ", "=", " ", 
         RowBox[{"assigns", " ", "/.", " ", "ren"}]}], ";", "\n", "  ", 
        RowBox[{"final", " ", "=", " ", 
         RowBox[{"final", " ", "/.", " ", "ren"}]}], ";", "\n", "  ", 
        RowBox[{"finalTerms", " ", "=", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Head", "[", "final", "]"}], " ", "===", " ", "Plus"}], 
           ",", " ", 
           RowBox[{"List", " ", "@@", " ", "final"}], ",", " ", 
           RowBox[{"{", "final", "}"}]}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"sup", " ", "=", " ", 
         RowBox[{
          RowBox[{"StringJoin", "[", "obsLabels", "]"}], " ", "<>", " ", 
          "\"\<|\>\"", " ", "<>", " ", 
          RowBox[{"StringJoin", "[", "charges", "]"}]}]}], ";", "\n", "  ", 
        RowBox[{"sub", " ", "=", " ", 
         RowBox[{"StringJoin", "[", 
          RowBox[{"ToString", " ", "/@", " ", "orders"}], "]"}]}], ";", "\n", 
        "  ", 
        RowBox[{"header", " ", "=", " ", 
         RowBox[{"StringRiffle", "[", 
          RowBox[{
           RowBox[{"{", "\n", "     ", 
            RowBox[{
             RowBox[{"cmtLine", "[", 
              RowBox[{
              "lang", ",", " ", 
               "\"\<Auto-generated by SAM-3.0 KappaExport.\>\""}], "]"}], ",",
              "\n", "     ", 
             RowBox[{"cmtLine", "[", 
              RowBox[{"lang", ",", " ", 
               RowBox[{
               "\"\<Cumulant kappa^{\>\"", " ", "<>", " ", "sup", " ", "<>", 
                " ", "\"\<}_{\>\"", " ", "<>", " ", "sub", " ", "<>", " ", 
                "\"\<} (total order \>\"", " ", "<>", "\n", "        ", 
                RowBox[{"ToString", "[", 
                 RowBox[{"Total", "[", "orders", "]"}], "]"}], " ", "<>", 
                " ", "\"\<, \>\"", " ", "<>", " ", 
                RowBox[{"ToString", "[", 
                 RowBox[{"Length", "[", "names", "]"}], "]"}], " ", "<>", 
                " ", "\"\< GCE-cumulant arguments).\>\""}]}], "]"}], ",", 
             "\n", "     ", 
             RowBox[{"cmtLine", "[", 
              RowBox[{
              "lang", ",", " ", 
               "\"\<Arguments are grand-canonical cumulants \
k_<obs><order..>_<charge><order..>, in signature order:\>\""}], "]"}], ",", 
             "\n", "     ", 
             RowBox[{"cmtLine", "[", 
              RowBox[{"lang", ",", " ", 
               RowBox[{"\"\<  \>\"", " ", "<>", " ", 
                RowBox[{"StringRiffle", "[", 
                 RowBox[{"names", ",", " ", "\"\<, \>\""}], "]"}]}]}], 
              "]"}]}], "}"}], ",", " ", "\"\<\\n\>\""}], "]"}]}], ";", "\n", 
        "  ", 
        RowBox[{"(*", " ", 
         RowBox[{"per", "-", 
          RowBox[{"language", " ", "syntax", " ", "tokens"}]}], " ", "*)"}], 
        "\n", "  ", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "preamble", ",", " ", "sig", ",", " ", "assignFmt", ",", " ", 
           "retSep", ",", " ", "retClose"}], "}"}], " ", "=", " ", 
         RowBox[{"Switch", "[", 
          RowBox[{"lang", ",", "\n", "   ", "\"\<Python\>\"", ",", " ", 
           RowBox[{"{", 
            RowBox[{"\"\<\>\"", ",", "\n", "     ", 
             RowBox[{
             "\"\<def \>\"", " ", "<>", " ", "fname", " ", "<>", " ", 
              "\"\<(\>\"", " ", "<>", " ", 
              RowBox[{"StringRiffle", "[", 
               RowBox[{"names", ",", " ", "\"\<, \>\""}], "]"}], " ", "<>", 
              " ", "\"\<):\\n\>\""}], ",", "\n", "     ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"\"\<    \>\"", " ", "<>", " ", 
                RowBox[{"SymbolName", "[", 
                 RowBox[{"First", "[", "#", "]"}], "]"}], " ", "<>", " ", 
                "\"\< = \>\"", " ", "<>", " ", 
                RowBox[{"emitCode", "[", 
                 RowBox[{
                  RowBox[{"Last", "[", "#", "]"}], ",", " ", "lang", ",", " ",
                   "obsLabels", ",", " ", "charges"}], "]"}], " ", "<>", " ", 
                "\"\<\\n\>\""}], ")"}], " ", "&"}], ",", "\n", "     ", 
             "\"\<\\n        + \>\"", ",", " ", "\"\<\\n    )\\n\>\""}], 
            "}"}], ",", "\n", "   ", "\"\<C\>\"", ",", " ", 
           RowBox[{"{", 
            RowBox[{
            "\"\<#include <math.h>\\nstatic inline double ipow(double b, int \
e){ double r = 1.0; int i; for (i = 0; i < e; i++) r *= b; return r; \
}\\n\\n\>\"", ",", "\n", "     ", 
             RowBox[{
             "\"\<double \>\"", " ", "<>", " ", "fname", " ", "<>", " ", 
              "\"\<(\>\"", " ", "<>", " ", 
              RowBox[{"StringRiffle", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"\"\<double \>\"", " ", "<>", " ", "#"}], ")"}], 
                  " ", "&"}], " ", "/@", " ", "names"}], ",", " ", 
                "\"\<, \>\""}], "]"}], " ", "<>", " ", "\"\<) {\\n\>\""}], 
             ",", "\n", "     ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"\"\<    double \>\"", " ", "<>", " ", 
                RowBox[{"SymbolName", "[", 
                 RowBox[{"First", "[", "#", "]"}], "]"}], " ", "<>", " ", 
                "\"\< = \>\"", " ", "<>", " ", 
                RowBox[{"emitCode", "[", 
                 RowBox[{
                  RowBox[{"Last", "[", "#", "]"}], ",", " ", "lang", ",", " ",
                   "obsLabels", ",", " ", "charges"}], "]"}], " ", "<>", " ", 
                "\"\<;\\n\>\""}], ")"}], " ", "&"}], ",", "\n", "     ", 
             "\"\<\\n      + \>\"", ",", " ", "\"\<\\n    );\\n}\\n\>\""}], 
            "}"}], ",", "\n", "   ", "_", ",", " ", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{
              RowBox[{"KappaExport", "::", "badlang"}], ",", " ", "lang"}], 
             "]"}], ";", " ", 
            RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}]}], ";", "\n", 
        "  ", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{"Stream", " ", "to", " ", "the", " ", "file", " ", "term"}],
           "-", "by", "-", 
          RowBox[{
          "term", " ", "rather", " ", "than", " ", "building", " ", "the", 
           " ", "whole", " ", "source", " ", 
           RowBox[{"string", ".", "\n", "     ", "For"}], " ", "the", " ", 
           "large", " ", "flat", " ", "output", " ", "this", " ", "keeps", 
           " ", "peak", " ", "memory", " ", 
           RowBox[{"low", ":", " ", 
            RowBox[{"each", " ", 
             RowBox[{"term", "'"}], "s", " ", "emitCode", "\n", "     ", 
             "result", " ", "is", " ", "written", " ", "and", " ", "freed", 
             " ", "instead", " ", "of", " ", "accumulating", " ", 
             RowBox[{"(", 
              RowBox[{"~", "GB"}], ")"}], " ", "before", " ", "one", " ", 
             "big", " ", 
             RowBox[{"join", "."}]}]}]}]}], " ", "*)"}], "\n", "  ", 
        RowBox[{"strm", " ", "=", " ", 
         RowBox[{"OpenWrite", "[", "file", "]"}]}], ";", "\n", "  ", 
        RowBox[{"WriteString", "[", 
         RowBox[{
         "strm", ",", " ", "header", ",", " ", "\"\<\\n\\n\>\"", ",", " ", 
          "preamble", ",", " ", "sig"}], "]"}], ";", "\n", "  ", 
        RowBox[{"Scan", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"WriteString", "[", 
            RowBox[{"strm", ",", " ", 
             RowBox[{"assignFmt", "[", "#", "]"}]}], "]"}], " ", "&"}], ",", 
          " ", "assigns"}], "]"}], ";", "\n", "  ", 
        RowBox[{"WriteString", "[", 
         RowBox[{"strm", ",", " ", "\"\<    return (\\n        \>\""}], "]"}],
         ";", "\n", "  ", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"WriteString", "[", 
           RowBox[{"strm", ",", " ", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"i", " ", "==", " ", "1"}], ",", " ", "\"\<\>\"", ",", 
              " ", "retSep"}], "]"}], ",", " ", 
            RowBox[{"emitCode", "[", 
             RowBox[{
              RowBox[{"finalTerms", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", " ", "lang", ",", " ", 
              "obsLabels", ",", " ", "charges"}], "]"}]}], "]"}], ",", "\n", 
          "     ", 
          RowBox[{"{", 
           RowBox[{"i", ",", " ", 
            RowBox[{"Length", "[", "finalTerms", "]"}]}], "}"}]}], "]"}], ";",
         "\n", "  ", 
        RowBox[{"WriteString", "[", 
         RowBox[{"strm", ",", " ", "retClose"}], "]"}], ";", "\n", "  ", 
        RowBox[{"Close", "[", "strm", "]"}], ";", "\n", "  ", "file"}]}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KappaExport", "::", "badlang"}], " ", "=", " ", 
     "\"\<Unknown \\\"Language\\\" `1`; use \\\"Python\\\" or \\\"C\\\" (or a \
.py/.c file extension).\>\""}], ";"}]}]}]], "Code",
