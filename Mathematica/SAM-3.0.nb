    RowBox[{"\"\<Limit\>\"", " ", "->", " ", "SAM1"}]}], "]"}], "    ", 
  RowBox[{"(*", " ", 
   RowBox[{
    SubsuperscriptBox["\[Kappa]", "1", 
     RowBox[{"X", "\[VerticalSeparator]", "B"}]], ",", " ", 
    RowBox[{"generic", " ", "observable"}]}], " ", "*)"}]}]], "Input",
 CellLabel->
  "In[157]:=",ExpressionUUID->"7c321905-3262-46a4-83a5-3567614f6ce0"],

