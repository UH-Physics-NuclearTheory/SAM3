      "coefficients", " ", 
      RowBox[{"lambda_k", "."}]}]}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"HessianElementSeries", ":", " ", 
