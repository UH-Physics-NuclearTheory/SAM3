        "]"}]}]}]}], ";", 
    RowBox[{"BinomialAcceptance", ":=", 
     RowBox[{
      RowBox[{"kGCE", "[", 
       RowBox[{"n_List", ",", "m_List"}], "]"}], ":>", 
      RowBox[{"kappaBinRule", "[", 
       RowBox[{"n", ",", "m"}], "]"}]}]}], ";"}]}]}]], "Code",
