Cell[CellGroupData[{

Cell["1.8 Top-level user API", "Subsection",ExpressionUUID->"c77cd643-a93f-4c39-91fd-8f2c3c261b30"],

Cell[TextData[{
 StyleBox["KappaCE", "Code"],
 " is the recommended user-facing front end: it computes a canonical cumulant \
and labels it in a single call, replacing the ",
 StyleBox["PaperForm[CanonicalPart[\[Ellipsis]]]", "Code"],
 " two-step.\n\n",
 StyleBox["KappaCE[obsLabels, orders, charges, opts]", "Code"],
 " \[LongDash] ",
 StyleBox["obsLabels", "Code"],
 " is the list of observable names (strings); ",
 StyleBox["orders", "Code"],
 " the per-observable cumulant orders (non-negative integers); ",
 StyleBox["charges", "Code"],
 " the list of conserved-charge names (strings). The observable count ",
 StyleBox["d = Length[orders]", "Code"],
 " and charge count ",
 StyleBox["s = Length[charges]", "Code"],
 " are inferred, so ",
 StyleBox["s", "Code"],
 " is never passed explicitly.\n\n",
 StyleBox["KappaCE[orders, charges, opts]", "Code"],
 " \[LongDash] short form: omit ",
 StyleBox["obsLabels", "Code"],
 " and they default to ",
 StyleBox["\"X\", \"Y\", \"Z\", \"W\", \[Ellipsis]", "Code"],
 ". The two forms are disambiguated automatically (observable labels are \
strings, orders are integers). ",
 StyleBox["charges", "Code"],
 " defaults to ",
 StyleBox["{\"B\"}", "Code"],
 "."
}], "Text",ExpressionUUID->"fbb465f4-0413-4dc3-8ac2-0b566427b7e4"],

Cell["Options:", "Text",ExpressionUUID->"65c50f82-4de6-4044-a19e-14eb0d5a724e"],

Cell[TextData[{
 StyleBox["\"Simplify\" -> FullSimplify", "Code"],
 " (default). Any function works (",
 StyleBox["Simplify", "Code"],
 ", ",
 StyleBox["Identity", "Code"],
 ", or e.g. ",
 StyleBox["FullSimplify[#, 0 < \[Alpha] < 1] &", "Code"],
 "). Prefer ",
 StyleBox["Simplify", "Code"],
 " or ",
 StyleBox["Identity", "Code"],
 " at high ",
 StyleBox["(n, d, s)", "Code"],
 ", where ",
 StyleBox["FullSimplify", "Code"],
 " is slow."
}], "Item",ExpressionUUID->"be2412f6-6f68-4ff9-b19d-f4db330b99aa"],

Cell[TextData[{
 StyleBox["\"NLO\" -> False", "Code"],
 " (default). ",
 StyleBox["True", "Code"],
 " returns the LO+NLO (finite-size-corrected) cumulant."
}], "Item",ExpressionUUID->"a8539c85-6214-4aed-8c09-862457f6d75f"],

Cell[TextData[{
 StyleBox["\"Form\" -> \"Paper\"", "Code"],
 " (default; typeset \[Kappa] in paper notation, via ",
 StyleBox["PaperForm", "Code"],
 "). ",
 StyleBox["\"Raw\"", "Code"],
 " returns the symbolic ",
 StyleBox["kGCE", "Code"],
 " expression (substitutable, e.g. ",
 StyleBox["/. SAM1", "Code"],
 "); ",
 StyleBox["\"TeX\"", "Code"],
 " returns a paper-style TeX string (via ",
 StyleBox["PaperTeXForm", "Code"],
 ")."
}], "Item",ExpressionUUID->"310904ca-b28f-47a5-988c-1ee24871c92b"],

Cell[TextData[{
 StyleBox["\"Limit\" -> None", "Code"],
 " (default). A replacement rule (or list of rules) applied to the cumulant \
before simplification \[LongDash] e.g. ",
 StyleBox["SAM1", "Code"],
 ", ",
 StyleBox["BinomialAcceptance", "Code"],
 ", or a user model rule. Pass a list of rule-sets, e.g. ",
 StyleBox["{SAM1, ObservableIsCharge}", "Code"],
 ", to apply them in sequence."
}], "Item",ExpressionUUID->"ef1cbeb9-6d0b-4b3a-bfab-649fde244e5e"],

Cell[TextData[{
 StyleBox["\"Method\" -> \"ColoredPartitions\"", "Code"],
 " (default; saddle-point recursion, Sec. 1.2). ",
 StyleBox["\"CoefficientMatching\"", "Code"],
 " uses the independent solver of Sec. 1.3 \[LongDash] useful as a \
cross-check. NLO is available only with ",
 StyleBox["\"ColoredPartitions\"", "Code"],
 "; ",
 StyleBox["\"CoefficientMatching\"", "Code"],
 " with ",
 StyleBox["\"NLO\" -> True", "Code"],
 " is an error."
}], "Item",ExpressionUUID->"c10157f5-dc7e-4071-b9f5-02a175037139"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", " ", 
       RowBox[{"KappaCE", ":", " ", 
        RowBox[{"top", "-", 
         RowBox[{"level", " ", "user"}], "-", 
         RowBox[{"facing", " ", "front", " ", 
          RowBox[{
           RowBox[{"end", " ", "--"}], "--"}], "\n", "   ", 
          RowBox[{"KappaCE", "[", 
           RowBox[{
           "obsLabels", ",", " ", "orders", ",", " ", "charges", ",", " ", 
            "opts"}], "]"}], "   ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"obsLabels", " ", "=", " ", "strings"}], ",", " ", 
            RowBox[{"orders", " ", "=", " ", "integers"}]}], ")"}], "\n", 
          "   ", 
          RowBox[{"KappaCE", "[", 
           RowBox[{"orders", ",", " ", "charges", ",", " ", "opts"}], "]"}], 
          "              ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"obsLabels", " ", "auto"}], "-", 
             RowBox[{"filled", " ", "\"\<X\>\""}]}], ",", "\"\<Y\>\"", ",", 
            "\"\<Z\>\"", ",", "\"\<W\>\"", ",", "..."}], ")"}], "\n", "   ", 
          "d"}]}]}]}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "orders", "]"}], " ", "and", " ", "s"}], " ", 
      "=", " ", 
      RowBox[{
       RowBox[{"Length", "[", "charges", "]"}], " ", "are", " ", 
       "inferred"}]}]}], ";", " ", 
    RowBox[{
     RowBox[{"s", " ", "is", " ", "never", " ", 
      RowBox[{"passed", ".", "\n", "   ", "Thin"}], " ", "wrapper", " ", 
      "over", " ", 
      RowBox[{"CanonicalPart", " ", "/", " ", "CanonicalNLO"}], " ", 
      RowBox[{"(", "computation", ")"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"PaperForm", " ", "/", "\n", "   ", "PaperTeXForm"}], " ", 
      RowBox[{
       RowBox[{"(", "display", ")"}], ".", " ", "The"}], " ", "two", " ", 
      "argument", " ", "forms", " ", "are", " ", "told", " ", "apart", " ", 
      "by", " ", "type", "\n", "   ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
        "string", " ", "labels", " ", "vs", " ", "integer", " ", "orders"}], 
        ")"}], "."}]}]}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"KappaCE", "::", "dmismatch"}], " ", "=", " ", 
     "\"\<`1` observable label(s) given for `2` order(s); the obsLabels and \
orders lists must have equal length.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KappaCE", "::", "orderzero"}], " ", "=", " ", 
     "\"\<Total cumulant order is zero; specify at least one positive \
order.\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KappaCE", "::", "badorders"}], " ", "=", " ", 
     "\"\<Order list `1` must consist of non-negative integers.\>\""}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KappaCE", "::", "badform"}], "   ", "=", " ", 
     "\"\<Unknown \\\"Form\\\" value `1`; use \\\"Paper\\\", \\\"Raw\\\", or \
\\\"TeX\\\".\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KappaCE", "::", "badmethod"}], " ", "=", " ", 
     "\"\<Unknown \\\"Method\\\" value `1`; use \\\"ColoredPartitions\\\" or \
\\\"CoefficientMatching\\\".\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KappaCE", "::", "nlomethod"}], " ", "=", " ", 
     "\"\<\\\"NLO\\\"->True is only available with \
\\\"Method\\\"->\\\"ColoredPartitions\\\" (no coefficient-matching \
NLO).\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KappaCE", "::", "badcall"}], "   ", "=", " ", 
     "\"\<Could not interpret the arguments. Usage: \
KappaCE[obsLabels:{__String}, orders:{__Integer}, charges:{__String}:{\\\"B\\\
\"}, opts] or KappaCE[orders:{__Integer}, charges:{__String}:{\\\"B\\\"}, \
opts].\>\""}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Options", "[", "KappaCE", "]"}], " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<Simplify\>\"", " ", "->", " ", "FullSimplify"}], ",", " ", 
       RowBox[{"\"\<NLO\>\"", " ", "->", " ", "False"}], ",", " ", 
       RowBox[{"\"\<Form\>\"", " ", "->", " ", "\"\<Paper\>\""}], ",", " ", 
       RowBox[{"\"\<Limit\>\"", " ", "->", " ", "None"}], ",", " ", 
       RowBox[{
       "\"\<Method\>\"", " ", "->", " ", "\"\<ColoredPartitions\>\""}]}], 
      "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"labels", "-", 
     RowBox[{"given", " ", "form"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KappaCE", "[", 
      RowBox[{
       RowBox[{"obsLabels", " ", ":", " ", 
        RowBox[{"{", "__String", "}"}]}], ",", " ", 
       RowBox[{"orders", " ", ":", " ", 
        RowBox[{"{", "__Integer", "}"}]}], ",", " ", 
       RowBox[{"charges", " ", ":", " ", 
        RowBox[{"{", "__String", "}"}], " ", ":", " ", 
        RowBox[{"{", "\"\<B\>\"", "}"}]}], ",", "\n", "      ", 
       RowBox[{"opts", " ", ":", " ", 
        RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], " ", ":=", " ", 
     RowBox[{"iKappaCE", "[", 
      RowBox[{
      "obsLabels", ",", " ", "orders", ",", " ", "charges", ",", " ", 
       "opts"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"labels", "-", 
     RowBox[{"auto", " ", 
      RowBox[{"form", ":", " ", 
       RowBox[{
       "first", " ", "argument", " ", "is", " ", "the", " ", "integer", " ", 
        "order", " ", "list"}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KappaCE", "[", 
      RowBox[{
       RowBox[{"orders", " ", ":", " ", 
        RowBox[{"{", "__Integer", "}"}]}], ",", " ", 
       RowBox[{"charges", " ", ":", " ", 
        RowBox[{"{", "__String", "}"}], " ", ":", " ", 
        RowBox[{"{", "\"\<B\>\"", "}"}]}], ",", " ", 
       RowBox[{"opts", " ", ":", " ", 
        RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], " ", ":=", "\n", 
     "  ", 
     RowBox[{"iKappaCE", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"i", " ", "<=", " ", "4"}], ",", " ", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "\"\<X\>\"", ",", " ", "\"\<Y\>\"", ",", " ", "\"\<Z\>\"", ",", 
              " ", "\"\<W\>\""}], "}"}], "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
           RowBox[{"\"\<X\>\"", " ", "<>", " ", 
            RowBox[{"ToString", "[", "i", "]"}]}]}], "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"i", ",", " ", 
           RowBox[{"Length", "[", "orders", "]"}]}], "}"}]}], "]"}], ",", 
       "\n", "    ", "orders", ",", " ", "charges", ",", " ", "opts"}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"anything", " ", 
     RowBox[{"else", ":", " ", 
      RowBox[{"friendly", " ", "usage", " ", "message"}]}]}], " ", "*)"}], 
   "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"KappaCE", "[", "___", "]"}], " ", ":=", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Message", "[", 
        RowBox[{"KappaCE", "::", "badcall"}], "]"}], ";", " ", "$Failed"}], 
      ")"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"shared", " ", 
      RowBox[{"worker", ":", " ", "validate"}]}], ",", " ", 
     RowBox[{"pick", " ", "solver"}], ",", " ", "compute", ",", " ", 
     RowBox[{"apply", " ", "limit", " ", "rules"}], ",", " ", "simplify", ",",
      " ", 
     RowBox[{"present", "."}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"iKappaCE", "[", 
      RowBox[{
      "obsLabels_List", ",", " ", "orders_List", ",", " ", "charges_List", 
       ",", " ", 
       RowBox[{"opts", " ", ":", " ", 
        RowBox[{"OptionsPattern", "[", "KappaCE", "]"}]}]}], "]"}], " ", ":=",
      "\n", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"d", " ", "=", " ", 
          RowBox[{"Length", "[", "orders", "]"}]}], ",", " ", 
         RowBox[{"s", " ", "=", " ", 
          RowBox[{"Length", "[", "charges", "]"}]}], ",", " ", "simp", ",", 
         " ", "form", ",", " ", "nlo", ",", " ", "lim", ",", " ", "method", 
         ",", " ", "specs", ",", " ", "computed", ",", " ", "raw", ",", " ", 
         "sfun"}], "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", " ", 
           RowBox[{"VectorQ", "[", 
            RowBox[{"orders", ",", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"IntegerQ", "[", "#", "]"}], " ", "&&", " ", 
                RowBox[{"#", " ", ">=", " ", "0"}]}], " ", "&"}], ")"}]}], 
            "]"}]}], ",", "\n", "     ", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"KappaCE", "::", "badorders"}], ",", " ", "orders"}], 
            "]"}], ";", " ", 
           RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}], ";", "\n", 
        "  ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "obsLabels", "]"}], " ", "!=", " ", "d"}], 
          ",", "\n", "     ", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"KappaCE", "::", "dmismatch"}], ",", " ", 
             RowBox[{"Length", "[", "obsLabels", "]"}], ",", " ", "d"}], 
            "]"}], ";", " ", 
           RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}], ";", "\n", 
        "  ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Total", "[", "orders", "]"}], " ", "==", " ", "0"}], ",", 
          " ", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{"KappaCE", "::", "orderzero"}], "]"}], ";", " ", 
           RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}], ";", "\n", 
        "  ", 
        RowBox[{"simp", "   ", "=", " ", 
         RowBox[{"OptionValue", "[", 
          RowBox[{"KappaCE", ",", " ", 
           RowBox[{"{", "opts", "}"}], ",", " ", "\"\<Simplify\>\""}], 
          "]"}]}], ";", "\n", "  ", 
        RowBox[{"nlo", "    ", "=", " ", 
         RowBox[{"OptionValue", "[", 
          RowBox[{"KappaCE", ",", " ", 
           RowBox[{"{", "opts", "}"}], ",", " ", "\"\<NLO\>\""}], "]"}]}], 
        ";", "\n", "  ", 
        RowBox[{"form", "   ", "=", " ", 
         RowBox[{"OptionValue", "[", 
          RowBox[{"KappaCE", ",", " ", 
           RowBox[{"{", "opts", "}"}], ",", " ", "\"\<Form\>\""}], "]"}]}], 
        ";", "\n", "  ", 
        RowBox[{"lim", "    ", "=", " ", 
         RowBox[{"OptionValue", "[", 
          RowBox[{"KappaCE", ",", " ", 
           RowBox[{"{", "opts", "}"}], ",", " ", "\"\<Limit\>\""}], "]"}]}], 
        ";", "\n", "  ", 
        RowBox[{"method", " ", "=", " ", 
         RowBox[{"OptionValue", "[", 
          RowBox[{"KappaCE", ",", " ", 
           RowBox[{"{", "opts", "}"}], ",", " ", "\"\<Method\>\""}], "]"}]}], 
        ";", "\n", "  ", 
        RowBox[{"sfun", "   ", "=", " ", 
         RowBox[{"simp", " ", "/.", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"True", " ", "->", " ", "Simplify"}], ",", " ", 
            RowBox[{"False", " ", "->", " ", "Identity"}]}], "}"}]}]}], ";", 
        "\n", "  ", 
        RowBox[{"(*", " ", 
         RowBox[{"\"\<Method\>\"", ":", " ", 
          RowBox[{
           RowBox[{"choose", " ", "the", " ", 
            RowBox[{"solver", ".", " ", "NLO"}], " ", "exists", " ", "only", 
            " ", "in", " ", "the", " ", "colored"}], "-", 
           RowBox[{"partition", " ", 
            RowBox[{"path", "."}]}]}]}], " ", "*)"}], "\n", "  ", 
        RowBox[{"computed", " ", "=", " ", 
         RowBox[{"Switch", "[", 
          RowBox[{
          "method", ",", "\n", "    ", "\"\<ColoredPartitions\>\"", ",", " ", 
           
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"TrueQ", "[", "nlo", "]"}], ",", " ", 
             RowBox[{"CanonicalNLO", "[", 
              RowBox[{"orders", ",", " ", "s"}], "]"}], ",", " ", 
             RowBox[{"CanonicalPart", "[", 
              RowBox[{"orders", ",", " ", "s"}], "]"}]}], "]"}], ",", "\n", 
           "    ", "\"\<CoefficientMatching\>\"", ",", " ", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"TrueQ", "[", "nlo", "]"}], ",", " ", 
             RowBox[{
              RowBox[{"Message", "[", 
               RowBox[{"KappaCE", "::", "nlomethod"}], "]"}], ";", " ", 
              RowBox[{"Return", "[", "$Failed", "]"}]}], ",", " ", 
             RowBox[{"CanonicalMatch", "[", 
              RowBox[{"orders", ",", " ", "s"}], "]"}]}], "]"}], ",", "\n", 
           "    ", "_", ",", "                     ", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{
              RowBox[{"KappaCE", "::", "badmethod"}], ",", " ", "method"}], 
             "]"}], ";", " ", 
            RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}]}], ";", "\n", 
        "  ", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{"\"\<Limit\>\"", ":", " ", 
           RowBox[{
            RowBox[{"apply", " ", "replacement", " ", "rule", 
             RowBox[{"(", "s", ")"}], " ", "before", " ", 
             RowBox[{"simplification", ".", " ", "A"}], " ", "list", " ", 
             "of", " ", "rule"}], "-", 
            RowBox[{"sets", "\n", "     ", 
             RowBox[{"(", 
              RowBox[{"e", ".", "g", ".", " ", 
               RowBox[{"{", 
                RowBox[{"SAM1", ",", " ", "ObservableIsCharge"}], "}"}]}], 
              ")"}], " ", "is", " ", "applied", " ", "in", " ", 
             "sequence"}]}]}], ";", " ", 
          RowBox[{
           RowBox[{"a", " ", "single", " ", "rule"}], "-", 
           RowBox[{
           "set", " ", "or", "\n", "     ", "bare", " ", "rule", " ", "is", 
            " ", "applied", " ", 
            RowBox[{"once", "."}]}]}]}], " ", "*)"}], "\n", "  ", 
        RowBox[{"specs", " ", "=", " ", 
         RowBox[{"Which", "[", 
          RowBox[{
           RowBox[{"lim", " ", "===", " ", "None"}], ",", " ", 
           RowBox[{"{", "}"}], ",", " ", 
           RowBox[{"MatchQ", "[", 
            RowBox[{"lim", ",", " ", 
             RowBox[{"{", "__List", "}"}]}], "]"}], ",", " ", "lim", ",", " ",
            "True", ",", " ", 
           RowBox[{"{", "lim", "}"}]}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{"With", " ", "no", " ", "limit"}], ",", " ", 
          RowBox[{"isolate", " ", "the", " ", "leading", " ", 
           RowBox[{"kappa", "^", "X_n"}], " ", "term", " ", 
           RowBox[{"(", 
            RowBox[{"=", " ", 
             RowBox[{"kGCE", "[", 
              RowBox[{"orders", ",", " ", "0"}], "]"}]}], ")"}], " ", "and", 
           "\n", "     ", "simplify", " ", "only", " ", "the", " ", 
           "corrections"}], ",", " ", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
              "so", " ", "every", " ", "order", " ", "prints", " ", "as", " ", 
               RowBox[{"kappa", "^", "X_n"}]}], " ", "+"}], " ", "..."}], "/", 
            RowBox[{"(", "...", ")"}]}], "\n", "     ", "instead", " ", "of", 
           " ", "FullSimplify", " ", "occasionally", " ", "pulling", " ", 
           "everything", " ", "over", " ", "one", " ", "denominator", "\n", 
           "     ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{
              "which", " ", "buries", " ", "the", " ", "leading", " ", 
               "term"}], ",", " ", 
              RowBox[{
              "as", " ", "it", " ", "does", " ", "at", " ", "order", " ", 
               "4"}]}], ")"}], "."}]}]}], " ", "*)"}], "\n", "  ", 
        RowBox[{"raw", "   ", "=", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"specs", " ", "===", " ", 
            RowBox[{"{", "}"}]}], ",", "\n", "            ", 
           RowBox[{
            RowBox[{"kGCE", "[", 
             RowBox[{"orders", ",", " ", 
              RowBox[{"ZeroMI", "[", "s", "]"}]}], "]"}], " ", "+", " ", 
            RowBox[{"sfun", "[", 
             RowBox[{"computed", " ", "-", " ", 
              RowBox[{"kGCE", "[", 
               RowBox[{"orders", ",", " ", 
                RowBox[{"ZeroMI", "[", "s", "]"}]}], "]"}]}], "]"}]}], ",", 
           "\n", "            ", 
           RowBox[{"sfun", "[", 
            RowBox[{"Fold", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"#1", " ", "/.", " ", "#2"}], ")"}], " ", "&"}], ",", 
              " ", "computed", ",", " ", "specs"}], "]"}], "]"}]}], "]"}]}], 
        ";", "\n", "  ", 
        RowBox[{"Switch", "[", 
         RowBox[{"form", ",", "\n", "    ", "\"\<Paper\>\"", ",", "   ", 
          RowBox[{"PaperForm", "[", 
           RowBox[{"raw", ",", " ", "obsLabels", ",", " ", "charges"}], "]"}],
           ",", "\n", "    ", "\"\<Raw\>\"", ",", "     ", "raw", ",", "\n", 
          "    ", "\"\<TeX\>\"", ",", "     ", 
          RowBox[{"PaperTeXForm", "[", 
           RowBox[{"raw", ",", " ", "obsLabels", ",", " ", "charges"}], "]"}],
           ",", "\n", "    ", "_", ",", "         ", 
          RowBox[{
           RowBox[{"Message", "[", 
            RowBox[{
             RowBox[{"KappaCE", "::", "badform"}], ",", " ", "form"}], "]"}], 
           ";", " ", "$Failed"}]}], "]"}]}]}], "\n", " ", "]"}]}], 
    ";"}]}]}]], "Code",
 CellLabel->
  "In[115]:=",ExpressionUUID->"57865269-7e8d-4021-a6dc-3e05483cac9f"]
}, Closed]],

Cell[CellGroupData[{

Cell["1.9 File export", "Subsection",ExpressionUUID->"09b772de-93ad-4a50-876d-f657f54a0a34"],

Cell[TextData[{
 StyleBox["KappaExport", "Code"],
 " writes a single canonical cumulant to a self-contained Python or C \
function, for use in external numerical codes \[LongDash] no labels, no TeX, \
machine-parseable.\n\n",
 StyleBox["KappaExport[obsLabels, orders, charges, file, opts]", "Code"],
 " computes the cumulant (via the same path as ",
 StyleBox["KappaCE", "Code"],
 "), then emits a function of the grand-canonical cumulants. Each GCE \
cumulant becomes a function argument named in the labeled flat scheme ",
 StyleBox["k_<obs><order\[Ellipsis]>_<charge><order\[Ellipsis]>", "Code"],
 " (e.g. ",
 StyleBox["k_X2Y1_B0Q2", "Code"],
 "), and the file header lists them as a legend.\n\nThe language is taken \
from the file extension (",
 StyleBox[".py", "Code"],
 " \[RightArrow] Python, ",
 StyleBox[".c", "Code"],
 "/",
 StyleBox[".h", "Code"],
 " \[RightArrow] C) or set explicitly via ",
 StyleBox["\"Language\"", "Code"],
 ". One cumulant per file; call twice (",
 StyleBox["kappa.py", "Code"],
 " and ",
 StyleBox["kappa.c", "Code"],
 ") for both."
}], "Text",ExpressionUUID->"fe7894fe-92f5-4837-8ba5-19ea0a65b5b8"],

Cell[TextData[{
 "Large cumulants: a fully inlined high-order multi-charge cumulant is \
enormous (order 4 at ",
 StyleBox["s = 3", "Code"],
 " is a ~300 MB expression / ~28 MB flat file and needs several GB to emit, \
since det K and its cofactors are inlined everywhere). Set ",
 StyleBox["\"CSE\" -> True", "Code"],
 " to apply common-subexpression elimination: det K / cofactors are computed \
once into local temporaries ",
 StyleBox["tmp1, tmp2, \[Ellipsis]", "Code"],
 ", shrinking that case to ~12 KB and keeping memory low. Off by default (the \
flat output is fine when memory is ample). For the flat C output, compile \
with ",
 StyleBox["-O0", "Code"],
 "/",
 StyleBox["-O1", "Code"],
 " (straight-line arithmetic; heavy optimization buys little and is slow)."
}], "Text",ExpressionUUID->"5277e9a2-b5b3-4284-8a92-bc4e1657a470"],

Cell["Options:", "Text",ExpressionUUID->"841e5a2d-0b92-483a-b487-2be44de467d6"],

Cell[TextData[{
 StyleBox["\"Language\"", "Code"],
 " (",
 StyleBox["Automatic", "Code"],
 ") \[LongDash] inferred from the file extension; set to override."
}], "Item",ExpressionUUID->"5736de3a-9ea2-4ea1-a2e9-908c9d6abb81"],

Cell[TextData[{
 StyleBox["\"FunctionName\"", "Code"],
 " (",
 StyleBox["\"kappa\"", "Code"],
 ") \[LongDash] name of the emitted function."
}], "Item",ExpressionUUID->"c0b33e0a-1902-4837-8221-700872b4a9f1"],

Cell[TextData[{
 StyleBox["\"CSE\"", "Code"],
 " (",
 StyleBox["False", "Code"],
 ") \[LongDash] ",
