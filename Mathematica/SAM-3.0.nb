    RowBox[{"\"\<Limit\>\"", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{"SAM1", ",", " ", "ObservableIsCharge"}], "}"}]}]}], "]"}], 
  "    ", 
  RowBox[{"(*", " ", 
   RowBox[{
    SubsuperscriptBox["\[Kappa]", "1", 
     RowBox[{
      SubscriptBox["B", "in"], "\[VerticalSeparator]", "B"}]], ",", " ", 
    RowBox[{"paper", " ", 
     RowBox[{"Eq", ".", " ", "73"}]}]}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.991183851588518*^9, 3.991183852104094*^9}},
 CellLabel->
