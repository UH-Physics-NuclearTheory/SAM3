Cell[CellGroupData[{

Cell["1.7 NLO finite-size corrections", "Subsection",ExpressionUUID->"282dc806-46b5-45d8-a68f-a4158e8bf3d3"],

Cell[TextData[{
 "NLO finite-size corrections from the multidimensional formula, paper Eq. \
(A12); the 1D formulas (A4) and (A5) are the ",
 StyleBox["d = s = 1", "Code"],
 " case.\n\nNLO is reached through ",
 StyleBox["KappaCE", "Code"],
 " with ",
 StyleBox["\"NLO\" -> True", "Code"],
 ". The internal workers are ",
 StyleBox["CanonicalNLO[n, s]", "Code"],
 " (LO+NLO, memoized) and its helpers ",
 StyleBox["CanonicalFromSaddleNLO[lambdaAssoc, n, s]", "Code"],
 " (two-step extractor) and ",
 StyleBox["DeltaSeries[lambdaAssoc, nMax, s]", "Code"],
 " (Hessian-determinant Taylor coefficients). ",
 StyleBox["ResetKappaCache[]", "Code"],
 " also clears the ",
 StyleBox["CanonicalNLO", "Code"],
 " cache."
}], "Text",ExpressionUUID->"055556fa-1b37-46b9-835f-e1c27919bc97"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"--", 
        RowBox[{"--", " ", "NLO"}]}], " ", "finite"}], "-", 
