     RowBox[{"management", " ", "--"}], "\n", "   ", "CanonicalPart", " ", 
     "and", " ", "CanonicalMatch", " ", "are", " ", 
     RowBox[{"memoized", "."}]}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"CanonicalPart", "[", 
      RowBox[{"n_List", ",", "s_Integer"}], "]"}], ":=", 
     RowBox[{
