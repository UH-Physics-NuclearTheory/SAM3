        RowBox[{
         RowBox[{"r", "=", 
          RowBox[{"KappaSaddlePoint", "[", 
           RowBox[{
            RowBox[{"Total", "[", "n", "]"}], ",", "d", ",", "s"}], "]"}]}], 
         ";", 
         RowBox[{"CanonicalFromSaddle", "[", 
          RowBox[{
           RowBox[{"r", "[", "\"\<lambdaAssoc\>\"", "]"}], ",", "n", ",", 
           "s"}], "]"}]}]}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
