          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"N1", "===", "Automatic"}], ",", 
            RowBox[{"Total", "[", "n", "]"}], ",", "N1"}], "]"}]}], ";", 
         RowBox[{"rules", "=", 
          RowBox[{"SolveLambdaCoefficientsCM", "[", 
           RowBox[{"d", ",", "s", ",", "maxDeg"}], "]"}]}], ";", 
         RowBox[{"CanonicalFromMatch", "[", 
          RowBox[{"rules", ",", "n", ",", "d", ",", "s", ",", "maxDeg"}], 
          "]"}]}]}], "]"}]}]}], ";"}], "\n", "\n", 
