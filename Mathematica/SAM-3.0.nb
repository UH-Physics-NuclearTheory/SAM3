Cell[CellGroupData[{

Cell["2.8 File export", "Subsection",ExpressionUUID->"bc200495-447f-4b10-8c22-28896baf1368"],

Cell[TextData[{
 StyleBox["KappaExport", "Code"],
 " writes one cumulant to a self-contained function of the grand-canonical \
cumulants, for use in external numerical codes. Python and C export are \
available. The function arguments are the GCE cumulants ",
 StyleBox["k_<obs><order..>_<charge><order..>", "Code"],
 " (listed in the file header).\n\nExported Python/C snippets are generated \
artifacts. By default they are written to ",
 StyleBox["generated/", "Code"],
 ", which is ignored by Git so that running the notebook does not clutter ",
 StyleBox["git status", "Code"],
 ". Remove ",
 StyleBox["generated/", "Code"],
 " from ",
 StyleBox[".gitignore", "Code"],
 " if you intentionally want to version-control these generated files."
}], "Text",
 CellChangeTimes->{
  3.991185552020741*^9, {3.991186348166999*^9, 3.991186350918058*^9}, 
   3.99118646933928*^9},ExpressionUUID->"cc06a4f9-55f1-41ba-926b-\
5028c33d1566"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"variance", " ", "with", " ", "B"}], ",", 
    RowBox[{"Q", " ", "conservation"}]}], " ", "*)"}], "\n", 
  RowBox[{"KappaExport", "[", 
   RowBox[{
    RowBox[{"{", "\"\<X\>\"", "}"}], ",", " ", 
    RowBox[{"{", "2", "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<B\>\"", ",", " ", "\"\<Q\>\""}], "}"}], ",", " ", 
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{"exportDir", ",", " ", "\"\<kappa2_BQ.py\>\""}], "}"}], "]"}]}],
    "]"}]}]], "Input",
 CellChangeTimes->{{3.991186508376867*^9, 3.991186509353973*^9}},
 CellLabel->
  "In[172]:=",ExpressionUUID->"b42cac58-542d-4e73-9d3c-8b78c0d3204a"],

