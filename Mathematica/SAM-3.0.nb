     RowBox[{
      RowBox[{"(", 
       RowBox[{"App", ".", " ", "A"}], ")"}], "."}]}]}], "\n", "*)"}], "\n", 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Options", "[", "BellSumKernel", "]"}], " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<IncludeLeading\>\"", " ", "->", " ", "True"}], ",", " ", 
       RowBox[{"\"\<ExcludeUnitPi\>\"", " ", "->", " ", "True"}]}], "}"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"BellSumKernel", "[", 
      RowBox[{
      "n_List", ",", " ", "lambdaAssoc_Association", ",", " ", "dd_Integer", 
       ",", " ", "ss_Integer", ",", "\n", "              ", "offsetMI_List", 
