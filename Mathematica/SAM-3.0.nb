Cell[CellGroupData[{

Cell["2. Examples", "Section",ExpressionUUID->"f0531db0-8e58-411d-ab9a-01273b0bc868"],

Cell[CellGroupData[{

Cell["2.1 Quick start", "Subsection",ExpressionUUID->"712ab32b-3f2b-4f62-9ea2-9a206f5f1f4b"],

Cell[TextData[{
 StyleBox["KappaCE", "Code"],
 " computes a canonical cumulant. Schema: ",
 StyleBox["KappaCE[obsLabels, orders, charges]", "Code"],
 " \[LongDash] where ",
 StyleBox["orders", "Code"],
 " is the list of per-observable cumulant orders and ",
 StyleBox["charges", "Code"],
 " the list of conserved-charge names; ",
 StyleBox["d = Length[orders]", "Code"],
 " observables and ",
 StyleBox["s = Length[charges]", "Code"],
 " charges are inferred. ",
 StyleBox["obsLabels", "Code"],
 " default to ",
 StyleBox["\"X\", \"Y\", \[Ellipsis]", "Code"],
 " and ",
 StyleBox["charges", "Code"],
 " to ",
 StyleBox["{\"B\"}", "Code"],
 ". See Sec. 1.8 for the full option list."
}], "Text",ExpressionUUID->"dde30b82-0cfa-46ac-bf9a-bbf78d6032e0"],

