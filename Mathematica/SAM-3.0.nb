Cell[CellGroupData[{

Cell["2.9 Simplification, performance, and cross-checks", "Subsection",ExpressionUUID->"fddb6372-c390-4120-893c-473bf1138832"],

Cell[TextData[{
 StyleBox["\"Simplify\"", "Code"],
 " sets the simplifier (",
 StyleBox["FullSimplify", "Code"],
 " by default; ",
 StyleBox["Simplify", "Code"],
 " or ",
 StyleBox["Identity", "Code"],
 " for faster, less-canonical output). At high orders simplification \
dominates the runtime, so prefer ",
 StyleBox["Simplify", "Code"],
 " or ",
 StyleBox["Identity", "Code"],
 " for realistic work:"
}], "Text",ExpressionUUID->"2cd55e4a-aeb7-48bd-9125-c1babf237c14"],

