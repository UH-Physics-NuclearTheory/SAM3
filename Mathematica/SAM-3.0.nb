Cell[CellGroupData[{

Cell["2.7 Finite-size NLO corrections", "Subsection",
 CellChangeTimes->{{3.991172114705197*^9, 
  3.9911721153703623`*^9}},ExpressionUUID->"18c7e1ef-39f2-427d-bf4e-\
bf7315c91278"],

Cell[TextData[{
 StyleBox["\"NLO\" -> True", "Code"],
 " returns the LO+NLO (finite-size-corrected) cumulant \[LongDash] the \
leading correction from the Gaussian saddle-point prefactor, of relative \
order ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "/", 
    SubsuperscriptBox["\[Kappa]", "2", "B"]}], TraditionalForm]],
  ExpressionUUID->"65a8598a-5826-4b84-a5d8-fa2de2e97373"],
 " (i.e. O(1/V) in an extensive system; paper Appendix A). The two examples \
below show one conserved charge (",
 StyleBox["s = 1", "Code"],
 ") and two (",
 StyleBox["s = 2", "Code"],
 ")."
}], "Text",
 CellChangeTimes->{{3.991184135524523*^9, 
  3.991184166654785*^9}},ExpressionUUID->"2e05dad9-8655-4beb-86cf-\
c812c4589415"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"KappaCE", "[", 
  RowBox[{
   RowBox[{"{", "2", "}"}], ",", " ", 
   RowBox[{"\"\<NLO\>\"", " ", "->", " ", "True"}]}], "]"}]], "Input",
 CellLabel->
  "In[169]:=",ExpressionUUID->"b9003704-cf39-4d55-961a-d608fdecb3ce"],

Cell[BoxData[
 TagBox[
  RowBox[{
   TemplateBox[{"\[Kappa]", "\"2\"", 
     StyleBox["\"X\"", Italic, StripOnInput -> False]},
    "Subsuperscript"], "+", 
   FractionBox[
    TagBox[
     RowBox[{
      RowBox[{"2", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         TemplateBox[{"\[Kappa]", "\"11\"", 
           StyleBox["\"XB\"", Italic, StripOnInput -> False]},
          "Subsuperscript"], ")"}], "2"], " ", 
